# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=Buymarjet
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Backend
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://buymarjet:buymarjet123@postgres:5432/buymarjet
DB_HOST=postgres
DB_PORT=5432
DB_USER=buymarjet
DB_PASSWORD=buymarjet123
DB_NAME=buymarjet

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRE=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@buymarjet.com

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# AWS S3 (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=buymarjet-uploads

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173

# API Keys
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_for_stock_data
